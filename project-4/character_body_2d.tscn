[gd_scene format=3 uid="uid://b7mw1k6j17rwh"]

[ext_resource type="Texture2D" uid="uid://c1okj6uxaoub5" path="res://HK head.png" id="2_ghijl"]

[sub_resource type="GDScript" id="GDScript_ij6vw"]
script/source = "extends CharacterBody2D

var nearby_interactables = []
const SPEED = 300.0
const JUMP_VELOCITY = -400.0


func _physics_process(delta: float) -> void:
	# Get the input direction and handle the movement/deceleration.
	# As good practice, you should replace UI actions with custom gameplay actions.
	var direction := Input.get_axis(\"ui_left\", \"ui_right\")
	velocity.x = direction * SPEED
	
	var verticaldirection := Input.get_axis(\"ui_up\", \"ui_down\")
	velocity.y = verticaldirection * SPEED
	
	if Input.is_action_just_pressed(\"Interact\"):
		if nearby_interactables:
			nearby_interactables.back().interact()

	move_and_slide()


func _on_interaction_detector_area_entered(area: Area2D) -> void:
	area.set_active(true)
	nearby_interactables.append (area)


func _on_interaction_detector_area_exited(area: Area2D) -> void:
	nearby_interactables.erase(area)


func _on_area_2d_area_entered(area: Area2D) -> void:
	print (\"enetered\")
	if Input.is_action_just_pressed(\"KEY_E\"):
		print (\"hi\")


func _on_area_2d_area_exited(area: Area2D) -> void:
	nearby_interactables.erase(area)
"

